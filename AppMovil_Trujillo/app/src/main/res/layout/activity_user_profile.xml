<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
             android:layout_width="match_parent"
             android:layout_height="match_parent">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/etTalla"
            android:hint="Talla (cm)"
            android:inputType="numberDecimal"
            android:layout_width="200dp"
            android:layout_height="40dp" />

        <EditText
            android:id="@+id/etPeso"
            android:hint="Peso (kg)"
            android:inputType="numberDecimal"
            android:layout_width="200dp"
            android:layout_height="40dp"/>


        <EditText
            android:id="@+id/etEdad"
            android:hint="Edad"
            android:inputType="number"
            android:layout_width="200dp"
            android:layout_height="40dp"/>

        <Spinner
            android:id="@+id/spGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etDiasSemana"
            android:hint="Días por semana que vas al gimnasio"
            android:inputType="number"
            android:layout_width="310dp"
            android:layout_height="40dp"/>

        <Spinner
            android:id="@+id/spNivel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etObservaciones"
            android:hint="Lesiones, enfermedades, etc. (opcional)"
            android:inputType="text"
            android:layout_width="330dp"
            android:layout_height="40dp"/>

        <Button
            android:id="@+id/btnGuardarPerfil"
            android:text="Guardar Perfil"
            android:layout_marginTop="16dp"
            android:layout_width="200dp"
            android:layout_height="40dp"/>
    </LinearLayout>
</ScrollView>